{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "CrystalCanvas",
    "version": "0.5.0",
    "identifier": "com.crystalcanvas.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build"
    },
    "app": {
        "macOSPrivateApi": true,
        "windows": [
            {
                "title": "CrystalCanvas",
                "width": 1280,
                "height": 800,
                "transparent": true,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true
            }
        ]
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "category": "Education",
        "copyright": "Copyright © 2026 CrystalCanvas Contributors",
        "shortDescription": "Next-generation crystal structure modeler with GPU-accelerated rendering"
    }
}