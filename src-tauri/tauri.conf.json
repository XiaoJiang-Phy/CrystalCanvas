{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "CrystalCanvas",
    "version": "0.1.0",
    "identifier": "com.crystalcanvas.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build"
    },
    "app": {
        "macOSPrivateApi": true,
        "windows": [
            {
                "title": "CrystalCanvas",
                "width": 1280,
                "height": 800,
                "transparent": true
            }
        ]
    }
}