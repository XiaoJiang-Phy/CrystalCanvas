! Quantum ESPRESSO input generated by CrystalCanvas
! WARNING: This is a geometry template. Verify all &CONTROL, &SYSTEM, &ELECTRONS parameters.

&CONTROL
  title = 'NaCl generated by CrystalCanvas',
  calculation = 'scf', prefix = 'NaCl', outdir = './tmp', verbosity = 'high',
  tprnfor = .true., tstress = .true., forc_conv_thr = 1.0d-7, etot_conv_thr = 1.0d-9, nstep = 100,
/

&SYSTEM
  ibrav = 0, nat = 2, ntyp = 2,
  A = 5.6400000000, B = 5.6400000000, C = 5.6400000000,
  cosAB = 0.0000000000, cosAC = 0.0000000000, cosBC = 0.0000000000,
  ecutwfc = 60, occupations = 'smearing', smearing = 'gauss', degauss = 1.0d-2,
/

&ELECTRONS
  conv_thr = 1.0d-12,
  mixing_beta = 0.3d0,
/

&IONS
/

&CELL
  press_conv_thr = 0.02,
/

ATOMIC_SPECIES
  Na 22.99000 Na.upf
  Cl 35.45000 Cl.upf

CELL_PARAMETERS (angstrom)
  5.6400000000 0.0000000000 0.0000000000
  0.0000000000 5.6400000000 0.0000000000
  0.0000000000 0.0000000000 5.6400000000

ATOMIC_POSITIONS (crystal)
  Na 0.0000000000 0.0000000000 0.0000000000
  Cl 0.5000000000 0.5000000000 0.5000000000

K_POINTS {automatic}
  5 5 5 0 0 0
